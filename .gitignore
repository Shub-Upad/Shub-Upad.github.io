# Ignore Quarto source and generated asset directories
*.qmd
.quarto/
_quarto/
quarto-cache/
_quarto_cache/
_quarto/

# Per-post Quarto `post_files/` (Bootstrap, quarto.js, etc.) is tracked so GitHub
# Pages can render viewer iframes the same as localhost.

# Ignore editor and system files
.DS_Store
*.swp
*.swo
*~

# Ignore local build artifacts
*.log
